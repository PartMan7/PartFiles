DATABASE_URL="file:./dev.db"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
CRON_SECRET="generate-a-random-secret-for-cron"
UPLOAD_DIR="./uploads"
INITIAL_ADMIN_PASSWORD="change-me-on-first-run"
BASE_URL="http://localhost:3000"
# Optional: separate domain for content URLs (/c/, /s/, /r/, /e/).
# Falls back to BASE_URL when unset.
# CONTENT_URL="https://cdn.example.com"

# Discord incoming webhooks
# DISCORD_GUEST_SIGNUP_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# DISCORD_ACCOUNT_UPGRADE_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# When 5+ self-registrations occur the same UTC day, signup messages prefix with a ping:
# DISCORD_REGISTRATION_ALERT_USER_ID="123456789012345678"

# Content abuse reports from the "Report content" action
# DISCORD_CONTENT_REPORT_WEBHOOK_URL="https://discord.com/api/webhooks/..."
# Mention this user ID in the report message (<@id>); optional if you only want the webhook text
# DISCORD_CONTENT_REPORT_USER_ID="123456789012345678"
